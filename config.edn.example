{;; Site title (default: name of the current directory).
 :title     "My website"

 ;; Base URL for absolute links (RSS, etc.). No trailing slash.
 :base-url  "https://example.com"

 ;; Copyright notice displayed in the footer.
 :copyright "© 2026 Author — Creative Commons BY-SA 4.0"

 ;; Languages to generate indexes and feeds for (default: ["en"]).
 ;; Language is detected from filenames: post.fr.org → "fr", post.en.org → "en".
 ;; Files without a language suffix default to "en".
 :languages ["en" "fr"]

 ;; Menu entries: list of slugs (filenames without lang/ext) to show in nav.
 ;; Matches root-level pages and section directories. Displayed in this order.
 ;; Entries can also be maps for external links: {:url "https://github.com/me" :description "GitHub"}
 ;; Can be a vector (same menu for all languages) or a map keyed by language.
 ;; If omitted, all root pages and sections are shown.
 ;; :menu ["about" "notes" {:url "https://codeberg.org/me" :description "Code"}]
 ;; :menu {:en ["notes" "about"] :fr ["notes" "a-propos"]}

 ;; Optional CSS theme, loaded after Pico 2.
 ;; Can be: a pico-themes name (e.g. "teletype"), an https:// URL,
 ;; a file:/// URL, or a path to a local .css file.
 ;; Leave empty or remove for default Pico styling.
 :theme "teletype"}
